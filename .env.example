# Database
# DATABASE_URL=postgresql+asyncpg://agent:agentpass@localhost:5432/dsagent
DATABASE_URL=postgresql+asyncpg://agent:agentpass@postgres:5432/dsagent


# # Redis / Celery
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Security
SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_V1_PREFIX=/v1
PROJECT_NAME="Data Scientist Agent"

# CELERY_TASK_ALWAYS_EAGER=True


# Choose backend: "local" or "openrouter"
LLM_BACKEND=local

# Local settings (used when LLM_BACKEND=local)
LOCAL_BASE_URL=http://172.17.0.1:11434/v1
LOCAL_MODEL=phi3:mini
LOCAL_API_KEY=dummy

# OpenRouter settings (used when LLM_BACKEND=openrouter)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_API_KEY=change-me-to-api-key

# Sandbox URL
SANDBOX_URL=http://sandbox:8001

# Max columns and rows that the llm sees,
# llm uses the whole data set to run the code and perform analysis
MAX_COLUMNS=50
MAX_SAMPLE_ROWS=10

# Agent will stop after AGENT_TIMEOUT seconds
AGENT_TIMEOUT=300

# Langfuse
LANGFUSE_PUBLIC_KEY=your_pk
LANGFUSE_SECRET_KEY=your_sk
LANGFUSE_HOST=https://cloud.langfuse.com  # or self-hosted
